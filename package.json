{
  "name": "mcp-wheelcheck",
  "version": "1.0.0",
  "description": "MCP server that checks whether a feature/tool already exists in the open-source ecosystem (npm, PyPI, crates.io, GitHub) before you build it yourself.",
  "type": "module",
  "license": "MIT",
  "author": "Tobias Pape",
  "homepage": "https://github.com/tobiaspape/mcp-wheelcheck",
  "repository": {
    "type": "git",
    "url": "github:tobiaspape/mcp-wheelcheck"
  },
  "bugs": {
    "url": "https://github.com/tobiaspape/mcp-wheelcheck/issues"
  },
  "bin": {
    "mcp-wheelcheck": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "mcp:inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "mcp-tools",
    "npm",
    "pypi",
    "crates-io",
    "github",
    "ecosystem",
    "prior-art",
    "dont-reinvent",
    "wheelcheck",
    "claude",
    "cursor",
    "opencode",
    "codex",
    "windsurf",
    "claude-code"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
